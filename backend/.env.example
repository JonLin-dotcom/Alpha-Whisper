# ============================================
# Alpha Whisper v2.1 - Environment Template
# Copy this to .env and fill in your values
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret - Generate a strong random string
# On macOS/Linux: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-min-32-characters

# ============================================
# Database Configuration
# ============================================

# For Local Development (MySQL on localhost)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=alpha_user
# DB_PASSWORD=your_local_password
# DB_NAME=alpha_whisper

# For Alibaba Cloud (华南1 Shenzhen)
DB_HOST=47.119.141.23
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Aa138088!
DB_NAME=alpha_whisper

# Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_ENABLE_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY=10000

# ============================================
# Rate Limiting (requests per minute)
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Cache Settings (in seconds)
# ============================================
PRICE_CACHE_TTL_SECONDS=60
HISTORICAL_CACHE_TTL_SECONDS=300

# ============================================
# Yahoo Finance Configuration
# ============================================
YAHOO_FINANCE_ENABLED=true
YAHOO_FINANCE_TIMEOUT=10000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
